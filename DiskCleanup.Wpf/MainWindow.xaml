<Window x:Class="DiskCleanup.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiskCleanup.Wpf"
        mc:Ignorable="d"
        Title="Disk Cleanup" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <Button x:Name="ScanButton" Content="Scan" Padding="10,4" Click="ScanButton_Click"/>
            <TextBlock Text="Filter by risk:" Margin="20,0,5,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="RiskFilterCombo" Width="120" SelectionChanged="RiskFilterCombo_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="SAFE"/>
                <ComboBoxItem Content="REVIEW"/>
                <ComboBoxItem Content="INFO"/>
            </ComboBox>
            <TextBlock x:Name="StatusText" Margin="20,0,0,0" VerticalAlignment="Center" Text="Click Scan to begin."/>
        </StackPanel>

        <!-- Results grid -->
        <DataGrid x:Name="ItemsGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="False" SelectionMode="Extended" RowHeight="28"
                  SelectionChanged="ItemsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}"
                                      IsEnabled="{Binding CanSelect}"
                                      HorizontalAlignment="Center"
                                      Click="ItemCheckBox_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Item" Binding="{Binding Label}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="90" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Details: full path + plain-language explanation for the selected row,
             since grid cells clip long labels with no way to see the rest. -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,10,0,0" Padding="8" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                <TextBlock x:Name="DetailsText" TextWrapping="Wrap"
                           Text="Select an item to see its full path and why it's categorized that way."/>
            </ScrollViewer>
        </Border>

        <!-- Action bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,10">
            <Button x:Name="SelectAllSafeButton" Content="Select all SAFE" Padding="10,4" Click="SelectAllSafeButton_Click"/>
            <Button x:Name="ClearSelectionButton" Content="Clear selection" Padding="10,4" Margin="10,0,0,0" Click="ClearSelectionButton_Click"/>
            <Button x:Name="CleanButton" Content="Clean Selected" Padding="10,4" Margin="10,0,0,0" Click="CleanButton_Click"/>
            <TextBlock x:Name="FreeSpaceText" Margin="20,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Log / results -->
        <TextBox x:Name="LogBox" Grid.Row="4" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" FontFamily="Consolas" Background="#F5F5F5"/>
    </Grid>
</Window>
